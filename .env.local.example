# Supabase - get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Anthropic - get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Claude model to use for the agent.
# Options (cheapest to most capable):
#   claude-haiku-4-5-20251001   $1 / $5 per MTok
#   claude-sonnet-4-6            $3 / $15 per MTok
#   claude-opus-4-6              $5 / $25 per MTok
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Stripe - get from https://dashboard.stripe.com/
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CORE_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Supabase service role key - only used in the Stripe webhook handler
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App base URL (used for Stripe redirect URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Monthly prompt limits per subscription tier (tune without code changes)
PROMPT_LIMIT_CORE=50
PROMPT_LIMIT_PRO=200
